# ─────────────────────────────────────────
#  TWITTER AGENT — ENVIRONMENT VARIABLES
#  Rename this file to .env after filling it in
#  Never share this file or commit it to git
# ─────────────────────────────────────────

# LLM provider: auto | anthropic | openai
# auto picks Anthropic first if both keys are present, then OpenAI
LLM_PROVIDER=auto

# Add at least one key:
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional model overrides
# ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-20241022
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Your Twitter handle (without @)
TWITTER_USERNAME=your_twitter_username_here

# Dashboard password (set anything you want)
DASHBOARD_PASSWORD=changeme123

# Secret key for Flask sessions (set any random string)
SECRET_KEY=change_this_to_a_random_string
